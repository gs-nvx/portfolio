<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="20250317-005" author="gioele">

        <addColumn tableName="configurator_package_services">
            <column name="included" type="TINYINT(1)" defaultValueNumeric="1">
                <constraints nullable="false"/>
            </column>
        </addColumn>

        <addColumn tableName="configurator_services">
            <column name="visible_for" type="VARCHAR(500)"/>
            <column name="exclusive_group" type="VARCHAR(100)"/>
            <column name="client_label" type="VARCHAR(200)"/>
            <column name="client_description" type="VARCHAR(500)"/>
            <column name="activity_type" type="VARCHAR(100)"/>
        </addColumn>

        <addColumn tableName="configurator_packages">
            <column name="activity_type" type="VARCHAR(100)"/>
        </addColumn>

        <rollback>
            <dropColumn tableName="configurator_packages" columnName="activity_type"/>
            <dropColumn tableName="configurator_services" columnName="visible_for"/>
            <dropColumn tableName="configurator_services" columnName="exclusive_group"/>
            <dropColumn tableName="configurator_services" columnName="client_label"/>
            <dropColumn tableName="configurator_services" columnName="client_description"/>
            <dropColumn tableName="configurator_services" columnName="activity_type"/>
            <dropColumn tableName="configurator_package_services" columnName="included"/>
        </rollback>

    </changeSet>

</databaseChangeLog>