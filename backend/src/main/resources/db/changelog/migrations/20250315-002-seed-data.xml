        <!-- Tutti i pacchetti includono i 5 servizi Base -->
        <sql>
            INSERT INTO configurator_package_services (package_id, service_id, included)
            SELECT p.id, s.id, 1
            FROM configurator_packages p
            CROSS JOIN configurator_services s
            WHERE s.category = 'Base';
        </sql>

